<!DOCTYPE html>
<html lang="da">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TrendAgent ETF Weekly — Uge {{ week_number }}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #f4f6f9; color: #2c3e50; font-size: 14px; }
    .header { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: white; padding: 20px 30px; display: flex; justify-content: space-between; align-items: center; }
    .header h1 { font-size: 22px; font-weight: 700; }
    .header h1 span { color: #4ecdc4; }
    .header-meta { font-size: 12px; color: #aaa; margin-top: 4px; }
    .badge-afkast { background: #4ecdc4; color: #1a1a2e; padding: 8px 16px; border-radius: 8px; text-align: center; }
    .badge-afkast .val { font-size: 22px; font-weight: 800; }
    .badge-afkast .lbl { font-size: 11px; opacity: 0.8; }
    .container { max-width: 1400px; margin: 0 auto; padding: 20px; }

    /* ALERTS */
    .alert-box { border-radius: 8px; padding: 14px 18px; margin-bottom: 16px; }
    .alert-trail { background: #fef3cd; border-left: 4px solid #f59c00; }
    .alert-portfolio { background: #fce8e6; border-left: 4px solid #d93025; }
    .alert-title { font-weight: 700; font-size: 13px; margin-bottom: 8px; }
    .alert-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid rgba(0,0,0,0.06); font-size: 13px; }
    .alert-row:last-child { border-bottom: none; }
    .tag-red { background: #d93025; color: white; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 700; }
    .tag-green { background: #1e8e3e; color: white; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 700; }
    .tag-gold { background: #f59c00; color: white; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 700; }

    /* SPEJDER */
    .spejder-box { background: white; border-radius: 10px; padding: 18px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); border-left: 4px solid #4ecdc4; }
    .spejder-title { font-size: 15px; font-weight: 700; color: #1a1a2e; margin-bottom: 12px; }
    .spejder-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 10px; }
    .spejder-card { background: #f8fbff; border: 1px solid #e0eaf5; border-radius: 8px; padding: 12px; }
    .spejder-card.golden { border-color: #f59c00; background: #fffdf0; }
    .spejder-name { font-weight: 700; font-size: 13px; color: #1a1a2e; margin-bottom: 4px; }
    .spejder-ticker { font-size: 11px; color: #888; margin-bottom: 6px; }
    .spejder-stats { display: flex; gap: 12px; font-size: 12px; margin-bottom: 6px; }
    .spejder-stat { color: #555; }
    .spejder-stat .val { font-weight: 700; color: #1e8e3e; }
    .spejder-reasons { font-size: 11px; color: #666; }
    .spejder-reasons span { display: block; }
    .ask-badge { display: inline-block; padding: 1px 7px; border-radius: 8px; font-size: 10px; font-weight: 700; margin-left: 4px; }
    .ask-badge.ask  { background: #e6f4ea; color: #1e6e34; border: 1px solid #a8d5b5; }
    .ask-badge.akt  { background: #fff3e0; color: #e65100; border: 1px solid #ffcc80; }
    .ask-badge.warn { background: #fce8e6; color: #c62828; border: 1px solid #f5c6c6; }
    .s-card { background: var(--bg, #fff5f5); border: 1px solid var(--bc, #e53935); border-radius: 10px; padding: 12px 14px; }
    .s-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 8px; }
    .s-name { font-weight: 700; font-size: 13px; color: #1a1a2e; line-height: 1.3; }
    .s-ticker { font-size: 11px; color: #888; margin-top: 2px; }
    .s-pile { font-size: 20px; font-weight: 700; min-width: 32px; text-align: right; }
    .s-badges { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 8px; align-items: center; }
    .s-badge { font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 6px; border: 1px solid; }
    .s-badge-score { background: #f5f5f5; color: #333; border-color: #ddd; }
    .s-badge-new { background: #e6f1fb; color: #0c447c; border-color: #85b7eb; }
    .s-badge-rsi { background: #fce8e6; color: #c62828; border-color: #f5c6c6; }
    .s-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; margin-bottom: 8px; }
    .s-stat { background: rgba(0,0,0,0.03); border-radius: 6px; padding: 5px 8px; }
    .s-stat-label { font-size: 10px; color: #888; margin-bottom: 1px; }
    .s-stat-value { font-size: 13px; font-weight: 700; }
    .s-detail-btn { font-size: 11px; color: #1976d2; cursor: pointer; background: none; border: none; padding: 0; text-decoration: underline; }
    .s-detail { display: none; margin-top: 10px; border-top: 1px solid rgba(0,0,0,0.07); padding-top: 10px; }
    .s-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 8px; }
    .s-detail-item { font-size: 11px; }
    .s-detail-label { color: #888; }
    .s-detail-value { color: #1a1a2e; font-weight: 600; }
    .s-compare { background: #e8f0fe; border: 1px solid #90b4f5; border-radius: 6px; padding: 6px 10px; font-size: 11px; color: #1a56c4; }
    .ask-badge { display: inline-block; padding: 1px 7px; border-radius: 8px; font-size: 10px; font-weight: 700; margin-left: 4px; }
    .ask-badge.ask  { background: #e6f4ea; color: #1e6e34; border: 1px solid #a8d5b5; }
    .ask-badge.akt  { background: #fff3e0; color: #e65100; border: 1px solid #ffcc80; }
    .ask-badge.warn { background: #fce8e6; color: #c62828; border: 1px solid #f5c6c6; }

    /* TOP/BUND */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .card { background: white; border-radius: 10px; padding: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .card-title { font-size: 13px; font-weight: 700; margin-bottom: 10px; color: #555; }
    .top-row { display: flex; justify-content: space-between; padding: 5px 0; border-bottom: 1px solid #f0f0f0; font-size: 12px; }
    .top-row:last-child { border-bottom: none; }
    .pos { color: #1e8e3e; font-weight: 700; }
    .neg { color: #d93025; font-weight: 700; }

    /* CHART */
    .chart-card { background: white; border-radius: 10px; padding: 16px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .chart-title { font-size: 13px; font-weight: 700; color: #555; margin-bottom: 12px; }

    /* TABEL */
    .table-card { background: white; border-radius: 10px; padding: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 16px; }
    .table-title { font-size: 15px; font-weight: 700; margin-bottom: 14px; color: #1a1a2e; }
    table { width: 100%; border-collapse: collapse; font-size: 12px; }
    th { background: #f0f4f8; padding: 8px 10px; text-align: left; font-weight: 600; color: #555; font-size: 11px; white-space: nowrap; }
    td { padding: 8px 10px; border-bottom: 1px solid #f5f5f5; vertical-align: middle; }
    tr.active-row { background: #fffef5; }
    tr.active-row td:first-child { border-left: 3px solid #f59c00; }
    tr:hover { background: #fafafa; }
    .trend-bull { background: #e6f4ea; color: #1e8e3e; padding: 2px 7px; border-radius: 10px; font-size: 11px; font-weight: 600; white-space: nowrap; }
    .trend-bear { background: #fce8e6; color: #d93025; padding: 2px 7px; border-radius: 10px; font-size: 11px; font-weight: 600; white-space: nowrap; }
    .trend-warmup { background: #f0f4f8; color: #888; padding: 2px 7px; border-radius: 10px; font-size: 11px; }
    .cross-golden { color: #e67e00; font-weight: 700; font-size: 11px; }
    .cross-death { color: #d93025; font-weight: 700; font-size: 11px; }
    .cross-none { color: #ccc; }
    .trail-tag { background: #d93025; color: white; padding: 2px 7px; border-radius: 8px; font-size: 10px; font-weight: 700; }
    .hwm-info { font-size: 10px; color: #888; }
    .category-tag { background: #e8f4fd; color: #1565c0; padding: 1px 6px; border-radius: 8px; font-size: 10px; }

    /* METODIK */
    .metodik { background: white; border-radius: 10px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 16px; }
    .metodik h3 { font-size: 14px; font-weight: 700; margin-bottom: 12px; color: #1a1a2e; border-bottom: 2px solid #4ecdc4; padding-bottom: 6px; }
    .metodik-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .metodik-col h4 { font-size: 12px; font-weight: 700; color: #4ecdc4; margin: 10px 0 6px; }
    .metodik-col p, .metodik-col li { font-size: 11px; color: #555; line-height: 1.6; }
    .metodik-col ul { padding-left: 16px; }
    .heatmap-etf-w { background: white; border-radius: 10px; padding: 14px 16px;
                     box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 16px;
                     border-left: 4px solid #4ecdc4; }
    .hm-grid-etf { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
    .hm-cat-etf { background: #f8fbff; border-radius: 8px; padding: 10px 12px;
                  border-left: 3px solid #4ecdc4; min-width: 150px; flex: 1; }
    .hm-cat-etf .cat-t { font-size: 11px; font-weight: 700; margin-bottom: 3px; }
    .hm-cat-etf .cat-a { font-size: 19px; font-weight: 800; margin-bottom: 5px; }
    .hm-cat-etf .cat-f { font-size: 11px; color: #666; display: flex; justify-content: space-between; padding: 2px 0; }
    /* KORRELATIONSTABEL */
    .corr-w { background: white; border-radius: 10px; padding: 14px 16px;
               box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 16px;
               border-left: 4px solid #7b1fa2; }
    .corr-w table { width: 100%; border-collapse: collapse; font-size: 12px; margin-top: 10px; }
    .corr-w th { font-size: 11px; font-weight: 700; color: #888; padding: 5px 8px;
                 border-bottom: 1px solid #eee; text-align: left; }
    .corr-w td { padding: 7px 8px; border-bottom: 1px solid #f5f5f5; vertical-align: middle; }
    .corr-w tr:last-child td { border-bottom: none; }
    .corr-pair { font-size: 12px; font-weight: 600; color: #1a1a2e; }
    .corr-ticker { font-size: 10px; color: #aaa; font-family: monospace; }
    .corr-num { font-weight: 700; font-size: 13px; }
    .corr-none  .corr-num { color: #d93025; }
    .corr-low   .corr-num { color: #f59c00; }
    .corr-ok    .corr-num { color: #1e8e3e; }
    .corr-good  .corr-num { color: #1e8e3e; }
    .corr-badge { display: inline-block; padding: 2px 8px; border-radius: 20px; font-size: 10px; font-weight: 700; }
    .corr-none  .corr-badge { background: #fce8e6; color: #d93025; }
    .corr-low   .corr-badge { background: #fff3e0; color: #f59c00; }
    .corr-ok    .corr-badge { background: #e8f5e9; color: #1e8e3e; }
    .corr-good  .corr-badge { background: #e8f5e9; color: #1e8e3e; }
    .corr-summary { font-size: 11px; color: #555; background: #f9f9f9; border-radius: 6px;
                    padding: 8px 10px; margin-top: 10px; line-height: 1.5; }
  </style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div>
    <h1>📡 TrendAgent <span>ETF Weekly</span></h1>
    <div class="header-meta">Uge {{ week_number }} | Dato: {{ report_date }}</div>
  </div>
  {% if avg_portfolio_return is not none %}
  <div class="badge-afkast">
    <div class="lbl">UGENS AFKAST (⭐)</div>
    <div class="val" style="color: {{ '#1a1a2e' if avg_portfolio_return >= 0 else '#d93025' }}">
      {{ '%+.2f'|format(avg_portfolio_return) }}%
    </div>
  </div>
  {% endif %}
</div>

<div class="container">

  <!-- TRAIL STOP ADVARSLER -->
  {% if trail_stop_alerts %}
  <div class="alert-box alert-trail">
    <div class="alert-title">⚠️ Trail Stop Advarsel — {{ trail_stop_alerts|length }} fond(e) udløst (tærskel: {{ trail_stop_pct }}%)</div>
    {% for a in trail_stop_alerts %}
    <div class="alert-row">
      <span><strong>{{ a.name }}</strong> &nbsp; <small style="color:#888">{{ a.isin }}</small></span>
      <span>
        HWM: {{ a.hwm }} &nbsp;|&nbsp; Nu: {{ a.curr }} &nbsp;
        <span class="tag-red">{{ '%+.1f'|format(a.fall_pct) }}% fra top</span>
        &nbsp; Afkast fra køb: {{ '%+.1f'|format(a.total_ret) }}%
      </span>
    </div>
    {% endfor %}
    <div style="font-size:11px; color:#888; margin-top:8px;">
      En advarsel er ikke automatisk et salgssignal — tjek fondens rank og 1M afkast før du handler.
    </div>
  </div>
  {% endif %}

  <!-- PORTFOLIO ALERTS -->
  {% if portfolio_alerts %}
  <div class="alert-box alert-portfolio">
    <div class="alert-title">📉 Kraftige fald i aktive positioner denne uge</div>
    {% for a in portfolio_alerts %}
    <div class="alert-row">
      <span>{{ a.name }}</span>
      <span class="tag-red">{{ '%+.1f'|format(a.change) }}%</span>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <!-- SPEJDER META -->
  {% if spejder_meta and spejder_meta.scanned_at %}
  <div style="font-size:11px; color:#888; margin-bottom:8px; padding: 6px 0;">
    🛰️ Spejder scannede {{ spejder_meta.total_scanned }} ETF'er · {{ spejder_meta.hurtige_hits }} hurtige · {{ spejder_meta.stabile_hits }} stabile · {{ spejder_meta.scanned_at }}
    &nbsp;·&nbsp; ⭐ ejet &nbsp;·&nbsp; 👁 watchlist &nbsp;·&nbsp; 🆕 ny
  </div>
  {% endif %}

  <!-- SPEJDER: HURTIGE HESTE -->
{% macro spejder_kort(s, accent_color, accent_bg, score_bg, score_color) %}
<div class="s-card" style="--bg: {{ accent_bg }}; --bc: {{ accent_color }};">
  <div class="s-header">
    <div>
      <div class="s-name">{{ '⭐ ' if s.is_owned else '👁 ' if s.is_watchlist else '' }}{{ s.name[:50] }}</div>
      <div class="s-ticker">{{ s.ticker }}</div>
    </div>
    <div class="s-pile" style="color: {{ '#27ae60' if s.momentum_pile in ['↑↑','↓↑'] else '#e53935' if s.momentum_pile == '↓↓' else '#f39c12' }}">
      {{ s.momentum_pile if s.momentum_pile else '—' }}
    </div>
  </div>
  <div class="s-badges">
    <span class="s-badge s-badge-score" style="background:{{ score_bg }}; color:{{ score_color }}; border-color:{{ accent_color }};">{{ s.score }}pt</span>
    {% if s.is_new_this_week %}<span class="s-badge s-badge-new">✦ Ny denne uge</span>{% endif %}
    {% if s.rsi and s.rsi >= 70 %}<span class="s-badge s-badge-rsi">RSI {{ '%.0f'|format(s.rsi) }} ⚠</span>{% endif %}
  </div>
  <div class="s-stats">
    <div class="s-stat">
      <div class="s-stat-label">Momentum</div>
      <div class="s-stat-value" style="color:{{ accent_color }};">+{{ s.momentum }}%</div>
    </div>
    <div class="s-stat">
      <div class="s-stat-label">1M afkast</div>
      <div class="s-stat-value">{{ '%+.1f'|format(s.return_1m) if s.return_1m is not none else '—' }}%</div>
    </div>
    <div class="s-stat">
      <div class="s-stat-label">1Y afkast</div>
      <div class="s-stat-value">{% if s.short_history %}— (ny){% elif s.return_1y is not none %}{{ '%+.1f'|format(s.return_1y) }}%{% else %}—{% endif %}</div>
    </div>
  </div>
  <button class="s-detail-btn" onclick="this.nextElementSibling.style.display = this.nextElementSibling.style.display === 'block' ? 'none' : 'block'; this.textContent = this.textContent.includes('▾') ? '▸ Detaljer ved handel' : '▾ Detaljer ved handel';">▾ Detaljer ved handel</button>
  <div class="s-detail">
    <div class="s-detail-grid">
      <div class="s-detail-item"><div class="s-detail-label">Depot</div><div class="s-detail-value">{% if s.ask_eligible == true %}<span class="ask-badge ask">ASK ✓</span>{% elif s.ask_eligible == false %}<span class="ask-badge akt">AKT</span>{% else %}—{% endif %}</div></div>
      <div class="s-detail-item"><div class="s-detail-label">Sektor</div><div class="s-detail-value">{{ s.category or '—' }}</div></div>
      <div class="s-detail-item"><div class="s-detail-label">Vægtet momentum</div><div class="s-detail-value">{{ '%+.1f'|format(s.weighted_momentum) if s.weighted_momentum else '—' }}</div></div>
      <div class="s-detail-item"><div class="s-detail-label">TER</div><div class="s-detail-value">{{ s.ter }}%</div></div>
      <div class="s-detail-item"><div class="s-detail-label">Trend</div><div class="s-detail-value">{% if s.reasons %}{{ s.reasons[-1][:30] }}{% else %}—{% endif %}</div></div>
      <div class="s-detail-item"><div class="s-detail-label">RSI</div><div class="s-detail-value">{{ '%.0f'|format(s.rsi) if s.rsi else '—' }}</div></div>
    </div>
    {% if s.weakest_owned and not s.is_owned %}
    <div class="s-compare">⇄ Stærkere end din svageste fond — {{ s.weakest_owned.ticker }} {{ s.weakest_owned.score }}pt</div>
    {% endif %}
    {% if s.portfolio_corr_label and s.portfolio_corr_label != '—' and not s.is_owned %}
    <div style="font-size:11px; margin-top:6px; padding-top:6px; border-top:1px solid rgba(0,0,0,0.05);">
      {% if s.portfolio_corr_css == 'corr-none' %}
      <span style="color:#d93025;">⚠️ Spredning mod din portefølje: {{ s.portfolio_corr_label }}</span>
      {% elif s.portfolio_corr_css == 'corr-low' %}
      <span style="color:#f59c00;">⚠️ Spredning mod din portefølje: {{ s.portfolio_corr_label }}</span>
      {% else %}
      <span style="color:#1e8e3e;">✅ Spredning mod din portefølje: {{ s.portfolio_corr_label }}</span>
      {% endif %}
    </div>
    {% endif %}
  </div>
</div>
{% endmacro %}

  {% if spejder_hurtige %}
  <div class="spejder-box" style="border-left-color: #e53935; background: white;">
    <div class="spejder-title" style="color: #e53935;">
      🚀 Hurtige Heste — Momentum &gt;20% eller 1Y &gt;50%
      <span style="font-size:11px; font-weight:normal; color:#888; margin-left:8px;">Høj risiko · Kræver aktiv overvågning · HWM passer på dig</span>
      {% if spejder_hurtige|length > 5 %}
      <span style="float:right; font-size:11px; font-weight:normal; color:#e53935; cursor:pointer;" onclick="toggleSpejder('hurtige')">
        Vis alle {{ spejder_hurtige|length }} ▾
      </span>
      {% endif %}
    </div>
    <div class="spejder-grid" id="spejder-hurtige">
      {% for s in spejder_hurtige[:5] %}
      {{ spejder_kort(s, '#e53935', '#fff5f5', '#fce8e6', '#c62828') }}
      {% endfor %}
    </div>
    {% if spejder_hurtige|length > 5 %}
    <div class="spejder-grid" id="spejder-hurtige-rest" style="display:none; margin-top:10px;">
      {% for s in spejder_hurtige[5:] %}
      {{ spejder_kort(s, '#e53935', '#fff5f5', '#fce8e6', '#c62828') }}
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  <!-- SPEJDER: STABILE TRENDERE -->
  {% if spejder_stabile %}
  <div class="spejder-box" style="border-left-color: #4ecdc4; background: white;">
    <div class="spejder-title" style="color: #0d9488;">
      📈 Stabile Trendere — Momentum 5-20%, RSI &lt;70
      <span style="font-size:11px; font-weight:normal; color:#888; margin-left:8px;">Lavere risiko · Langsigtet momentum · HWM holder øje</span>
      {% if spejder_stabile|length > 5 %}
      <span style="float:right; font-size:11px; font-weight:normal; color:#0d9488; cursor:pointer;" onclick="toggleSpejder('stabile')">
        Vis alle {{ spejder_stabile|length }} ▾
      </span>
      {% endif %}
    </div>
    <div class="spejder-grid" id="spejder-stabile">
      {% for s in spejder_stabile[:5] %}
      {{ spejder_kort(s, '#0d9488', '#f0fdfa', '#e0f2f1', '#00695c') }}
      {% endfor %}
    </div>
    {% if spejder_stabile|length > 5 %}
    <div class="spejder-grid" id="spejder-stabile-rest" style="display:none; margin-top:10px;">
      {% for s in spejder_stabile[5:] %}
      {{ spejder_kort(s, '#0d9488', '#f0fdfa', '#e0f2f1', '#00695c') }}
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  <!-- TOP/BUND -->
  <div class="two-col">
    <div class="card">
      <div class="card-title">🚀 Ugens Top 5</div>
      {% for r in top_up %}
      <div class="top-row">
        <span>{{ '⭐ ' if r.is_active else '' }}{{ r.name[:38] }}</span>
        <span class="pos">{{ '%+.2f'|format(r.week_change_pct) }}%</span>
      </div>
      {% endfor %}
    </div>
    <div class="card">
      <div class="card-title">📉 Ugens Svageste 5</div>
      {% for r in top_down %}
      <div class="top-row">
        <span>{{ '⭐ ' if r.is_active else '' }}{{ r.name[:38] }}</span>
        <span class="{{ 'neg' if r.week_change_pct < 0 else 'pos' }}">{{ '%+.2f'|format(r.week_change_pct) }}%</span>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- MOMENTUM CHART -->
  <div class="chart-card">
    <div class="chart-title">📊 Top 10 Stærkeste Trends (Momentum % fra {{ rows[0].ma_label if rows else 'MA' }})</div>
    <canvas id="momentumChart" height="80"></canvas>
  </div>

  <!-- HOVED TABEL -->
  <div class="table-card">
    <div class="table-title">📋 Alle ETF'er</div>
    <table>
      <thead>
        <tr>
          <th>Fond</th>
          <th>Uge %</th>
          <th>Afkast fra køb</th>
          <th>Trend</th>
          <th>Momentum %</th>
          <th>Cross</th>
          <th>RSI</th>
          <th>1M %</th>
          <th>1Y %</th>
          <th>Drawdown</th>
          <th>Trail Stop</th>
        </tr>
      </thead>
      <tbody>
        {% for row in rows %}
        <tr class="{{ 'active-row' if row.is_active else '' }}">

          <td>
            {{ '⭐ ' if row.is_active else '' }}
            <strong>{{ row.name[:40] }}</strong>
            {% if row.is_active and row.rsi_alert %}
              <span style="font-size:11px;" title="{{ 'RSI ' + '%.0f'|format(row.rsi) + ' — overkøbt (≥70)' if row.rsi_alert == 'overkøbt' else 'RSI ' + '%.0f'|format(row.rsi) + ' — oversolgt (≤30)' }}">{{ '🔴' if row.rsi_alert == 'overkøbt' else '🔵' }}</span>
            {% endif %}
            <br>
            <span style="font-size:10px; color:#888;">{{ row.ticker }}</span>
            <span class="category-tag" style="margin-left:4px;">{{ row.category.split('—')[-1].strip()[:15] }}</span>
          </td>

          <td style="color: {{ '#1e8e3e' if row.week_change_pct > 0 else '#d93025' }}; font-weight: 600;">
            {{ '%+.2f'|format(row.week_change_pct) }}%
          </td>

          <td style="font-weight: 700; color: {{ '#1e8e3e' if (row.total_return or 0) >= 0 else '#d93025' }}">
            {% if row.is_active %}
              {{ '%+.2f'|format(row.total_return) if row.total_return is not none else '–' }}%
            {% else %}
              <span style="color:#ccc;">—</span>
            {% endif %}
          </td>

          <td>
            <span class="{{ 'trend-bull' if row.trend_state == 'BULL' else 'trend-bear' if row.trend_state == 'BEAR' else 'trend-warmup' }}">
              {{ row.trend_state }}
            </span>
            <small style="color:#aaa; font-size:10px;">({{ row.ma_label }})</small>
          </td>

          <td style="color: {{ '#1e8e3e' if row.momentum >= 0 else '#d93025' }}; font-weight: 600;">
            {{ '%+.2f'|format(row.momentum) }}%
          </td>

          <td class="{{ 'cross-golden' if 'GOLDEN' in row.cross_20_50 else 'cross-death' if 'DEATH' in row.cross_20_50 else 'cross-none' }}">
            {{ row.cross_20_50 }}
          </td>

          <td style="color: {{ '#d93025' if row.rsi and row.rsi >= 70 else '#1565c0' if row.rsi and row.rsi <= 30 else '#555' }}">
            {{ '%.0f'|format(row.rsi) if row.rsi else '–' }}
          </td>

          <td style="color: {{ '#1e8e3e' if (row.return_1m or 0) >= 0 else '#d93025' }}">
            {{ '%+.1f'|format(row.return_1m) if row.return_1m is not none else '–' }}%
          </td>

          <td style="color: {{ '#1e8e3e' if (row.return_1y or 0) >= 0 else '#d93025' }}">
            {{ '%+.1f'|format(row.return_1y) if row.return_1y is not none else '–' }}%
          </td>

          <td style="color: {{ '#d93025' if row.is_active and row.drawdown < -0.1 else '#888' }};">
            {% if row.is_active and row.hwm %}
              {{ '%.1f'|format(row.drawdown) }}%
            {% else %}
              <span style="color:#ddd;">—</span>
            {% endif %}
          </td>

          <td>
            {% if row.trail_alert %}
              <span class="trail-tag">{{ '%+.1f'|format(row.trail_alert.fall_pct) }}% fra top</span>
            {% elif row.is_active and row.hwm %}
              <span class="hwm-info">HWM: {{ row.hwm }}</span>
            {% else %}
              <span style="color:#ddd;">—</span>
            {% endif %}
          </td>

        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <!-- SEKTOR HEATMAP -->
  {% if heatmap_data %}
  <div class="heatmap-etf-w">
    <div style="font-size:13px; font-weight:700; color:#1a1a2e; margin-bottom:8px;">🗺️ Sektor-eksponering — ETF</div>
    {% if heatmap_warning %}
    <div style="background:#fffdf0; border:1px solid #f59c00; border-radius:6px; padding:5px 9px; font-size:11px; color:#856404; margin-bottom:8px;">
      ⚠️ Koncentration: <strong>{{ heatmap_warning.kategori }}</strong> = {{ heatmap_warning.andel_pct }}%
    </div>
    {% endif %}
    <div class="hm-grid-etf">
      {% for kat in heatmap_data %}
      <div class="hm-cat-etf" style="border-left-color: {{ kat.farve }};">
        <div class="cat-t" style="color: {{ kat.farve }};">{{ kat.kategori }}</div>
        <div class="cat-a" style="color: {{ kat.farve }};">{{ kat.andel_pct }}%</div>
        {% for fond in kat.fonde %}
        <div class="cat-f">
          <span>{{ fond.ticker or fond.navn | truncate(18, true, '…') }}</span>
          <span class="{{ 'pos' if fond.positiv else 'neg' }}" style="font-weight:700;">{{ fond.total_return }}</span>
        </div>
        {% endfor %}
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <!-- KORRELATIONSTABEL -->
  {% if corr_pairs %}
  <div class="corr-w">
    <div style="font-size:13px; font-weight:700; color:#1a1a2e; margin-bottom:4px;">🔗 Spredning mellem positioner</div>
    <div style="font-size:11px; color:#888; margin-bottom:4px;">Beregnet på 90 dages daglige afkast</div>
    <table>
      <thead>
        <tr>
          <th style="width:38%">Par</th>
          <th style="width:12%">Korrelation</th>
          <th style="width:28%">Seneste 90 dage</th>
          <th>Vurdering</th>
        </tr>
      </thead>
      <tbody>
        {% for p in corr_pairs %}
        <tr class="{{ p.css }}">
          <td>
            <div class="corr-pair">{{ p.ticker_a }} + {{ p.ticker_b }}</div>
            <div class="corr-ticker">{{ p.navn_a | truncate(22, true, '…') }} + {{ p.navn_b | truncate(22, true, '…') }}</div>
          </td>
          <td><span class="corr-num">{{ p.korr_str }}</span></td>
          <td style="font-size:11px; color:#555;">{{ p.periode }}</td>
          <td>
            {% if p.advarsel %}
            <span class="corr-badge">⚠️ {{ p.vurdering }}</span>
            {% else %}
            <span class="corr-badge">✅ {{ p.vurdering }}</span>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if corr_summary %}
    <div class="corr-summary">{{ corr_summary }}</div>
    {% endif %}
  </div>
  {% endif %}

  <!-- METODIK -->
  <div class="metodik">
    <h3>📖 Fuld Metodik & Definitioner</h3>
    <div class="metodik-grid">
      <div class="metodik-col">
        <h4>📡 Spejderen</h4>
        <p>Finder ETF'er du ikke ejer, som opfylder alle tre kriterier:</p>
        <ul>
          <li><strong>BULL-trend:</strong> Kurs over bedste tilgængelige MA</li>
          <li><strong>Momentum ≥ {{ 5 }}%:</strong> Fonden har styrke</li>
          <li><strong>RSI &lt; 70:</strong> Ikke overkøbt endnu</li>
          <li><strong>Bonus — Golden Cross:</strong> MA20 krydser MA50 opad</li>
        </ul>

        <h4>📈 Trend & Momentum</h4>
        <ul>
          <li><strong>MA200:</strong> Primær indikator — kræver ~9 måneder data</li>
          <li><strong>MA50:</strong> Fallback indtil MA200 er tilgængeligt</li>
          <li><strong>Momentum %:</strong> Afstand fra kurs til bedste MA</li>
          <li><strong>BULL</strong> = kurs over MA &nbsp;·&nbsp; <strong>BEAR</strong> = kurs under MA</li>
        </ul>

        <h4>🔀 Cross</h4>
        <ul>
          <li><strong>🚀 GOLDEN:</strong> MA20 krydser op over MA50 — positivt signal</li>
          <li><strong>💀 DEATH:</strong> MA20 krydser ned under MA50 — negativt signal</li>
        </ul>
      </div>
      <div class="metodik-col">
        <h4>⚠️ Trail Stop (High Water Mark)</h4>
        <ul>
          <li>Beskytter gevinster ved at advare når en fond falder mere end {{ trail_stop_pct }}% fra sit toppunkt</li>
          <li><strong>HWM</strong> = højeste kurs siden køb — opdateres automatisk</li>
          <li><strong>Fald fra top</strong> = (kurs / HWM − 1) × 100</li>
          <li>En advarsel er ikke et salgssignal — brug din vurdering</li>
        </ul>

        <h4>📊 Afkast</h4>
        <ul>
          <li><strong>Uge %:</strong> Afkast de seneste 7 dage fra historikken</li>
          <li><strong>Total %:</strong> Afkast siden køb (aktive) eller siden første datapunkt</li>
          <li><strong>1M / 1Y:</strong> Beregnet fra historikken</li>
        </ul>

        <h4>⭐ Ugens Afkast</h4>
        <p>Simpelt gennemsnit af alle aktive positioners ugeafkast. Bruges som hurtigt pejlemærke — ikke som præcis porteføljeafkast.</p>

        <div class="disclaimer">
          Vi følger momentum og relativ styrke. Vi køber ETF'er der er stærkere end deres historiske gennemsnit (BULL-trend), og overvejer at rotere ud af ETF'er der mister momentum. Systemet giver signaler — du tager beslutningerne.
        </div>
      </div>
    </div>
  </div>

</div>

<!-- CHART.JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
<script>
  // Fix 4: Toggle Spejder vis alle
  function toggleSpejder(type) {
    const rest = document.getElementById('spejder-' + type + '-rest');
    const btn = event.target;
    if (rest.style.display === 'none') {
      rest.style.display = 'grid';
      btn.textContent = 'Skjul ▴';
    } else {
      rest.style.display = 'none';
      btn.textContent = 'Vis alle ▾';
    }
  }

  // Fix 6: Skjul Cross-kolonne hvis alle er –
  document.addEventListener('DOMContentLoaded', function() {
    const crossCells = document.querySelectorAll('td.cross-none');
    const allCross = document.querySelectorAll('table tbody td:nth-child(6)');
    const hasData = Array.from(allCross).some(td => td.textContent.trim() !== '–');
    if (!hasData) {
      // Skjul header og alle cross-celler
      const ths = document.querySelectorAll('table th');
      if (ths[5]) ths[5].style.display = 'none';
      allCross.forEach(td => td.style.display = 'none');
    }
  });

  // Momentum chart
  const ctx = document.getElementById('momentumChart').getContext('2d');
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: {{ chart_labels | tojson }},
      datasets: [{
        label: 'Momentum % fra MA',
        data: {{ chart_values | tojson }},
        backgroundColor: {{ chart_values | tojson }}.map(v =>
          v > 0 ? 'rgba(78, 205, 196, 0.7)' : 'rgba(217, 48, 37, 0.6)'
        ),
        borderColor: {{ chart_values | tojson }}.map(v =>
          v > 0 ? 'rgba(78, 205, 196, 1)' : 'rgba(217, 48, 37, 1)'
        ),
        borderWidth: 1,
        borderRadius: 4,
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => `Momentum: ${ctx.raw > 0 ? '+' : ''}${ctx.raw.toFixed(2)}%`
          }
        }
      },
      scales: {
        y: {
          grid: { color: '#f0f0f0' },
          ticks: { callback: v => v + '%', font: { size: 11 } }
        },
        x: {
          grid: { display: false },
          ticks: { font: { size: 10 }, maxRotation: 30 }
        }
      }
    }
  });
</script>

</body>
</html>
